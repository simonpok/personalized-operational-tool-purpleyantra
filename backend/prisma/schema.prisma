generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String       @id @default(cuid())
  name        String
  description String?
  isArchived  Boolean      @default(false)
  goals       Goal[]
  departments Department[]
  createdAt   DateTime     @default(now())
}

model Goal {
  id          String   @id @default(cuid())
  title       String
  s1          String   // Start State
  s2          String   // End State
  order       Int      @default(0)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lists       BoardList[]
  tasks       Task[]
  progress    Float    @default(0)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Department {
  id        String  @id @default(cuid())
  name      String
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  progress  Float   @default(0)
  color     String  // hex color for UI
}

model BoardList {
  id        String   @id @default(cuid())
  title     String
  order     Int
  goalId    String
  color     String?  // left border accent color
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  goalId       String
  goal         Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  listId       String
  list         BoardList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  subtasks     Subtask[]
  assignees    User[]     @relation("TaskAssignees")
  checklists   Checklist[]
  attachments  Attachment[]

  // TRU Scoring Base (Legacy/Fallback)
  technicality Int
  regularity   Int
  urgency      Int
  truScore     Float

  // Computed TRU from checklists
  avgT        Float?
  avgR        Float?
  avgU        Float?
  truOverall  Float?

  labels      String?    // Comma-separated or JSON string of colors

  startDate    DateTime?
  dueDate      DateTime?
  reminder     String?
  gcalEventId  String?
  progress     Float      @default(0)
  createdAt    DateTime   @default(now())
  
  comments     Comment[]
}

model Subtask {
  id           String     @id @default(cuid())
  title        String
  taskId       String
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status       String     @default("DOING")
  assignees    User[]     @relation("SubtaskAssignees")
  technicality Int
  regularity   Int
  urgency      Int
  truScore     Float
  dueDate      DateTime?
  progress     Float      @default(0)
}

model User {
  id       String    @id @default(cuid())
  name     String
  email    String    @unique
  avatar   String?
  role     String    @default("MEMBER")
  tasks    Task[]    @relation("TaskAssignees")
  subtasks Subtask[] @relation("SubtaskAssignees")
  comments Comment[]
  checklistItems ChecklistItem[]
}

model Checklist {
  id        String          @id @default(cuid())
  title     String
  taskId    String
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items     ChecklistItem[]
  createdAt DateTime        @default(now())
}

model ChecklistItem {
  id          String    @id @default(cuid())
  title       String
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  
  T           Int?      // 1, 2, or 3
  R           Int?      // 1, 2, or 3
  U           Int?      // 1, 2, or 3
  truAvg      Float?

  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])

  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  type      String   @default("FILE") // FILE | LINK
  size      Int?     // bytes
  mimeType  String?
  preview   String?  // OG image or thumbnail
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String?  // null if system log
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
}

